<?xml version="1.0"?>
<!--
  ClickHouse HTTP handlers that serve the Altinity SQL Browser from this
  cluster. Drop into the server's config.d/ (or push as an ACM cluster
  setting named "config.d/sql-browser.xml"), then reload/restart.

  Routes:
    GET /sql              -> the SPA (dist/sql.html in user_files)
    GET /sql/dashboard    -> the SAME SPA (client-side route: the favorites dashboard)
    GET /sql/config.json  -> the OAuth config (issuer + client_id [+ audience])

  The SPA POSTs queries to "/" with `Authorization: Bearer <id_token>`; that is
  handled by ClickHouse's built-in dynamic query handler (the <defaults/> rule),
  so no extra route is needed for query execution. ClickHouse must be configured
  to accept the JWT (token_processor / JWKS, or a delegated http_authentication
  verifier) — see README "Installing on any ClickHouse cluster".

  Each <rule> carries a unique `name=` attribute to dodge the ClickHouse
  config.d merge bug (#70636) where unnamed sibling rules overwrite each other.
  NOTE: it must be the `name=` attribute, not a <name> child element — ClickHouse
  26.3.x rejects a <name> child with "Unknown element in config:
  http_handlers.rule.name" and fails to start.
-->
<clickhouse>
  <http_handlers>
    <rule name="sql_browser_spa">
      <!-- Serves the SPA for both the workbench (/sql) and the client-side
           dashboard route (/sql/dashboard) from the same sql.html. The
           config.json rule below is anchored separately, so it still matches. -->
      <url>regex:^/sql(/dashboard)?/?$</url>
      <methods>GET</methods>
      <handler>
        <type>static</type>
        <content_type>text/html; charset=UTF-8</content_type>
        <http_response_headers>
          <Cache-Control>no-store</Cache-Control>
          <!-- connect-src OIDC origins: install.sh rewrites the https:// hosts from
               the issuer (via OIDC discovery). For a manual install with a non-Google
               IdP, replace the two https:// hosts below with your issuer + token
               endpoint origins. script-src/style-src need 'unsafe-inline' because the
               JS + CSS are inlined into this single HTML file; the real protection is
               connect-src, which bounds where the sessionStorage tokens can be sent.
               frame-src 'self' permits the cell-detail drawer's HTML preview, which
               renders a result value in a sandbox="" (script-less, inert) srcdoc iframe. -->
          <Content-Security-Policy>default-src 'none'; script-src 'unsafe-inline'; style-src 'unsafe-inline'; img-src data:; font-src 'self'; frame-src 'self'; connect-src 'self' https://accounts.google.com https://oauth2.googleapis.com; base-uri 'none'; frame-ancestors 'none'</Content-Security-Policy>
          <X-Content-Type-Options>nosniff</X-Content-Type-Options>
          <Referrer-Policy>no-referrer</Referrer-Policy>
        </http_response_headers>
        <response_content>file://sql.html</response_content>
      </handler>
    </rule>

    <rule name="sql_browser_config">
      <url>regex:^/sql/config\.json$</url>
      <methods>GET</methods>
      <handler>
        <type>static</type>
        <content_type>application/json; charset=UTF-8</content_type>
        <http_response_headers>
          <Cache-Control>no-store</Cache-Control>
          <X-Content-Type-Options>nosniff</X-Content-Type-Options>
          <Referrer-Policy>no-referrer</Referrer-Policy>
        </http_response_headers>
        <response_content>file://sql-config.json</response_content>
      </handler>
    </rule>

    <!-- Keep ClickHouse's built-in handlers (incl. the dynamic query handler
         the SPA POSTs to at "/") after the custom static aliases. -->
    <defaults/>
  </http_handlers>
</clickhouse>
