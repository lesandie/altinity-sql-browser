<?xml version="1.0"?>
<!--
  Sample clickhouse-client connections file for the Altinity SQL Browser local
  runner. This is a TEMPLATE shipped with the release bundle (as
  config.example.xml) — it does NOT replace your real
  ~/.clickhouse-client/config.xml.

  The runner reads ~/.clickhouse-client/config.xml by default. Point it at this
  file instead with LOCAL_CH_CONFIG, e.g.:

      LOCAL_CH_CONFIG=~/.altinity-sql-browser/config.example.xml altinity-sql-browser

  Each <connection> becomes a "Saved connection" in the login picker. Fields the
  runner reads: name, hostname, http_port (default 8443 secure / 8123 plain),
  secure, user, password, accept-invalid-certificate, and the oauth-* keys.
-->
<config>
  <connections_credentials>
    <!-- Plain username/password over HTTPS (prefills the credentials form). -->
    <connection>
      <name>my-cluster</name>
      <hostname>clickhouse.example.com</hostname>
      <secure>1</secure>
      <user>default</user>
      <password></password>
    </connection>

    <!-- Local ClickHouse over plain HTTP. -->
    <connection>
      <name>localhost</name>
      <hostname>localhost</hostname>
      <http_port>8123</http_port>
      <user>default</user>
    </connection>

    <!-- A dev tenant with a self-signed / invalid TLS cert: the picker surfaces a
         one-time "trust the certificate" step before connecting. -->
    <connection>
      <name>dev-tenant</name>
      <hostname>support.tenant.dev.altinity.cloud</hostname>
      <secure>1</secure>
      <user>admin</user>
      <accept-invalid-certificate>1</accept-invalid-certificate>
    </connection>

    <!-- OAuth / SSO sign-in against the cluster (PKCE public client). An optional
         oauth-client-secret enables a Web client (e.g. Google) for the code
         exchange; a non-empty oauth-audience switches the bearer to the access
         token (audience-gated ClickHouse). -->
    <connection>
      <name>sso-cluster</name>
      <hostname>clickhouse.example.com</hostname>
      <secure>1</secure>
      <oauth-url>https://accounts.google.com</oauth-url>
      <oauth-client-id>YOUR_CLIENT_ID</oauth-client-id>
      <oauth-audience></oauth-audience>
    </connection>
  </connections_credentials>
</config>
